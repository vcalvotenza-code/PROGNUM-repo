   "source": [
    "## Julian Date "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "ca2b6cd7-6024-4d3b-9cca-1492ddcb0cc2",
   "metadata": {},
   "outputs": [],
   "source": [
    "D=float(input(\"Day:\"))\n",
    "M=int(input(\"Month:\"))\n",
    "Y=int(input(\"Year:\"))\n",
    "JD = 367*Y -7*(Y+(M+9)/12)/4 - 3*((Y+(M-9)/7)/100 + 1)/4 + (275*M)/9 + D + 1721029-0.5\n",
    "print(f\"The Julian Date is: \", JD)"
   ]
  }
